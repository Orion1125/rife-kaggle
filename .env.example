# Kaggle credentials. Either:
#   1. Set these in .env (loaded by the CLI), or
#   2. Place ~/.kaggle/kaggle.json (the file Kaggle gives you under
#      Settings -> Account -> Create New Token).
#
# The Kaggle username is what your datasets and kernels are namespaced under.
KAGGLE_USERNAME=
KAGGLE_KEY=

# Default target fps (override with --fps).
RIFE_TARGET_FPS=120

# Default RIFE model. Currently only "v4.6" is tested.
# Change RIFE_MODEL_GDRIVE_ID to point at a different Google Drive zip if you
# have a newer trained checkpoint.
RIFE_MODEL_VERSION=v4.6
RIFE_MODEL_GDRIVE_ID=1APIzVeI-4ZZCEuIRE1m6WYfSCaOsi_7_
